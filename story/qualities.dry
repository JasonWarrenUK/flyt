# -- Qualities (stats) for the flyt contest --

# How sharp your insults are
@quality wit
name: Wit
type: integer
initial: 3

# Your standing in the community
@quality renown
name: Renown
type: integer
initial: 0

# How drunk you are (affects options)
@quality mead
name: Mead-Courage
type: integer
initial: 0

# Opponent's composure
@quality opponent_composure
name: Opponent's Composure
type: integer
initial: 5

# Crowd favour
@quality crowd
name: Crowd Favour
type: integer
initial: 0
